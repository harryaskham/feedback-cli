# direnv configuration. Run `direnv allow` once after instantiating.
#
# `use flake` loads this project's devShell (cargo, rustc, clippy, rust-analyzer)
# automatically on `cd`.
use flake

# CACOPHONY_PROJECT lets the cacophony tooling associate this checkout with a
# project. By default we derive it from the git repository name; override it by
# replacing the line below with an explicit value, e.g.
#   export CACOPHONY_PROJECT=my-project
export CACOPHONY_PROJECT="$(basename "$(git rev-parse --show-toplevel 2>/dev/null || pwd)")"
